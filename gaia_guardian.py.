import time
import random

# Hardware Abstraction Layer for ADS1115 ADC
try:
    import board
    import busio
    import adafruit_ads1x15.ads1115 as ADS
    from adafruit_ads1x15.analog_in import AnalogIn
    HAS_HARDWARE = True
except ImportError:
    HAS_HARDWARE = False
    print("[SYSTEM] Hardware not detected. Simulation Mode active.")

class GaiaGuardian:
    def __init__(self):
        self.baseline_stress = 0
        self.stress_threshold = 0
        self.is_calibrated = False
        self.sample_pool = []
        
        if HAS_HARDWARE:
            self.i2c = busio.I2C(board.SCL, board.SDA)
            self.ads = ADS.ADS1115(self.i2c)
            self.gsr_channel = AnalogIn(self.ads, ADS.P0)

    def calibrate_driver(self):
        """
        Learning Phase: Collects 15 samples to establish 
        the driver's unique physiological baseline.
        """
        print("\n[GAIA] Initialization: Starting 30-second Auto-Calibration...")
        print("[GAIA] Please breathe normally and remain still.")
        
        for i in range(15):
            val = self.read_raw_data()
            self.sample_pool.append(val)
            print(f"Calibration Progress: [{i+1}/15]")
            time.sleep(2)
            
        self.baseline_stress = sum(self.sample_pool) / len(self.sample_pool)
        # Threshold set at 25% above baseline (Adjustable sensitivity)
        self.stress_threshold = self.baseline_stress * 1.25 
        self.is_calibrated = True
        
        print(f"\n[GAIA] Calibration Complete.")
        print(f"Baseline: {int(self.baseline_stress)} | Threshold: {int(self.stress_threshold)}")
        print("--- Protection Active ---\n")

    def read_raw_data(self):
        if HAS_HARDWARE:
            return self.gsr_channel.value
        return random.randint(28000, 32000) # Stable simulation data

    def monitor_fitness(self):
        """Continuous monitoring after calibration."""
        if not self.is_calibrated:
            self.calibrate_driver()

        try:
            while True:
                current_val = self.read_raw_data()
                print(f"[MONITOR] Value: {current_val} (Limit: {int(self.stress_threshold)})")
                
                if current_val > self.stress_threshold:
                    self.trigger_camp_mode()
                
                time.sleep(2)
        except KeyboardInterrupt:
            print("\n[GAIA] Guardian shutting down. Travel safe, Stellina.")

    def trigger_camp_mode(self):
        print("\n!!! [GAIA ALERT] Stress levels exceeding baseline !!!")
        print(">> Action: Activating Support Protocol / Safe Stop.\n")

if __name__ == "__main__":
    guardian = GaiaGuardian()
    guardian.monitor_fitness()
